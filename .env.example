# Frontend — leave unset in dev (Vite proxies /api and /health to :8788).
# Set only for production preview or direct bridge access:
# VITE_COGNEE_PROXY_URL=http://localhost:8788
# VITE_COGNEE_PROXY_DIRECT=true

# Backend bridge — Cognee Cloud + LLM keys required
MEMGATEQA_MOCK=false
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your_api_key_here
COGNEE_SESSION_ID=memgateqa-1719320000
COGNEE_DATASET=default_dataset

# LLM agent — Gemini recommended (gemini-2.5-flash)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# MemGate Memory Engine is native (data/memory.json)
# Auto loop interval in seconds (observe→recall→grade→plan until ship-ready)
MEMGATEQA_LOOP_INTERVAL_SEC=120
MEMGATEQA_BRIDGE_URL=http://localhost:8788
MEMGATEQA_AUTO_AUDIT=true

# Autonomous Memory Gate — auto-runs after remember()/new evidence (debounced)
MEMGATEQA_AUTONOMOUS=true
MEMGATEQA_GATE_MAX_REPAIR_CYCLES=3
MEMGATEQA_GATE_AUTO_CERTIFY=true