{
  "name": "memgateqa",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "MemGateQA — QA, repair, and proof layer for Cognee-powered agent memory.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "bridge": "python server/cognee_bridge.py",
    "bridge:win": ".venv\\Scripts\\python server/cognee_bridge.py",
    "dev:all": "concurrently -k -n bridge,vite -c cyan,green \"npm run bridge:win\" \"npm run dev\"",
    "mcp": ".venv\\Scripts\\python server/mcp_memgateqa.py",
    "cli": ".venv\\Scripts\\python server/memgate_cli.py",
    "mcp:config": ".venv\\Scripts\\python server/memgate_cli.py mcp-config",
    "loop:run": ".venv\\Scripts\\python server/memgate_cli.py loop run case-wolfpack",
    "loop:auto": ".venv\\Scripts\\python server/memgate_cli.py loop auto start case-wolfpack --interval 120",
    "audit": ".venv\\Scripts\\python server/memgate_cli.py audit case-wolfpack",
    "agent:run": ".venv\\Scripts\\python server/memgate_cli.py agent run-all case-wolfpack",
    "agent:fleet": ".venv\\Scripts\\python server/memgate_cli.py agent run-fleet",
    "start": "npm run dev:all",
    "zip": "powershell -ExecutionPolicy Bypass -File scripts/build-submission.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
