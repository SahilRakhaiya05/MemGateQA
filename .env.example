# Frontend
VITE_MEMGATEQA_MOCK=false
VITE_COGNEE_PROXY_URL=http://localhost:8788

# Backend bridge — get these from Cognee Cloud console (Integrations → API / MCP)
MEMGATEQA_MOCK=false
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your_api_key_here
COGNEE_SESSION_ID=memgateqa-1719320000
COGNEE_DATASET=default_dataset

# LLM agent — OpenAI or Gemini (mock fallback when unset)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# MemGate Memory Engine is native (data/memory.json) — no external Supermemory API needed
